<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dekra.harm0niz3r">

    <!-- Network access for the TCP server -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Foreground service (required since Android 9) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Query installed packages (required since Android 11) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"
        xmlns:tools="http://schemas.android.com/tools" />
    <!-- Keep CPU awake during assessment -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".Harm0nizerService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

    </application>

</manifest>
